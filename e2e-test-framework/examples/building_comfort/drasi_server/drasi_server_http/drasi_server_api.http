# This file is for use with the REST Client extension for Visual Studio Code to make it easy to manually 
# test the Test Service Web API.
# https://marketplace.visualstudio.com/items?itemName=humao.rest-client

@hostname = localhost
@port = 8080
@source_id = facilities-db
@query_id = building-comfort
@reaction_id = rooms-http

# DOCS
### API Docs
GET http://{{hostname}}:{{port}}/docs

### OpenAPI Spec 
GET http://{{hostname}}:{{port}}/api-docs/openapi.json

# SERVER
### Server Health Check
GET http://{{hostname}}:{{port}}/health

# SOURCES
### GET List of Sources
GET http://{{hostname}}:{{port}}/sources

### GET a specific Source
GET http://{{hostname}}:{{port}}/sources/{{source_id}}

# QUERIES
### GET List of Queries
GET http://{{hostname}}:{{port}}/queries

### GET a specific Query
GET http://{{hostname}}:{{port}}/queries/{{query_id}}

### GET a specific Query's Results
GET http://{{hostname}}:{{port}}/queries/{{query_id}}/results

# REACTIONS
### GET List of Reactions
GET http://{{hostname}}:{{port}}/reactions

### GET a specific Reaction
GET http://{{hostname}}:{{port}}/reactions/{{reaction_id}}