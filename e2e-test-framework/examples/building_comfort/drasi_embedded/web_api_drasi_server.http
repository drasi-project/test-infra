# This file is for use with the REST Client extension for Visual Studio Code to make it easy to manually 
# test the Test Service Web API.
# https://marketplace.visualstudio.com/items?itemName=humao.rest-client

@hostname = localhost
@port = 63123
@repo_id = local_dev_repo
@test_id = building_comfort
@test_run_id = test_run_001
@drasi_server_id = embedded-drasi-server
@fq_test_run_id = {{repo_id}}.{{test_id}}.{{test_run_id}}

### GET LIST of Drasi instances in a Test Run
GET http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/drasi_servers

### GET STATE of a specific Drasi instances
GET http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/drasi_servers/{{drasi_server_id}}

