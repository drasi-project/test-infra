{
  "data_store": {
      "data_store_path": "examples/building_comfort/drasi_server/drasi_server_redis/test_data_cache",
      "delete_on_start": true,
      "delete_on_stop": true,
      "test_repos": [
          {
              "id": "local_dev_repo",
              "kind": "LocalStorage",
              "source_path": "examples/building_comfort/drasi_server/drasi_server_redis/dev_repo",
              "local_tests": [
                  {
                      "test_id": "building_comfort",
                      "version": 1,
                      "description": "Building comfort test using Redis for communication between E2ETF and Drasi Server",
                      "test_folder": "building_comfort",
                      "sources": [
                        {
                          "test_source_id": "facilities-db",
                          "kind": "Model",
                          "source_change_dispatchers": [
                            {
                              "kind": "RedisStream",
                              "host": "localhost",
                              "port": 6379,
                              "stream_name": "facilities-db-change",
                              "max_len": 10000,
                              "batch_size": 100,
                              "batch_timeout_ms": 100
                            },
                            {
                              "kind": "JsonlFile",
                              "max_lines_per_file": 15000
                            }
                          ],
                          "model_data_generator": {
                            "kind": "BuildingHierarchy",
                            "change_interval": [2000000000, 500000000, 500000000, 4000000000],
                            "change_count": 20,
                            "seed": 123456789,
                            "spacing_mode": "none",
                            "time_mode": "2025-01-03T10:03:15.4Z",
                            "building_count": [1, 0],
                            "floor_count": [1, 0],
                            "room_count": [1, 0],
                            "room_sensors": [
                                {
                                    "kind": "NormalFloat",
                                    "id": "temperature",
                                    "momentum_init": [5, 1, 0.5],
                                    "value_change": [1, 0],
                                    "value_init": [5000, 0],
                                    "value_range": [0, 10000]
                                },
                                {
                                    "kind": "NormalFloat",
                                    "id": "co2",
                                    "momentum_init": [10, 1, 0.5],
                                    "value_change": [1, 0],
                                    "value_init": [5000, 0],
                                    "value_range": [0, 10000]
                                },
                                {
                                    "kind": "NormalFloat",
                                    "id": "humidity",
                                    "momentum_init": [5, 1, 0.5],
                                    "value_change": [1, 0],
                                    "value_init": [5000, 0],
                                    "value_range": [0, 10000]
                                }
                            ]
                          },
                          "subscribers": [
                            { "node_id": "default", "query_id": "building-comfort" }
                          ]
                        }
                      ],
                      "queries": [
                        {
                          "test_query_id": "building-comfort",
                          "result_stream_handler": {
                            "kind": "RedisStream",
                            "host": "localhost",
                            "port": 6379,
                            "stream_name": "building-comfort-results",
                            "process_old_entries": false
                          },
                          "stop_trigger": {
                            "kind": "RecordCount",
                            "record_count": 20
                          }
                        }
                      ],
                      "reactions": []
                    }
              ]
          }
      ]
  },
  "test_run_host": {
      "test_runs": [
          {
              "test_id": "building_comfort",
              "test_repo_id": "local_dev_repo",
              "test_run_id": "test_run_001",
              "sources": [
                  {
                      "test_source_id": "facilities-db",
                      "start_mode": "auto"
                  }
              ],
              "queries": [
                {
                  "test_query_id": "building-comfort",
                  "start_immediately": true,
                  "loggers": [
                    {
                      "kind": "Profiler",
                      "write_bootstrap_log": true,
                      "write_change_image": true,
                      "write_change_log": true,
                      "write_change_rates": true,
                      "write_distributions": true
                    },
                    {
                      "kind": "JsonlFile",
                      "max_lines_per_file": 15000
                    }
                  ]
                }
              ]
          }
      ]
  }
}