FROM mcr.microsoft.com/azurelinux/base/rust:1.86 AS builder
RUN tdnf update -y && tdnf install -y protobuf-devel cmake openssl-devel clang-devel

WORKDIR /usr/src
COPY ./reactivator ./reactivator
# This image builds reactivator as a standalone crate (no workspace root
# copied), so strip the `[lints] workspace = true` stanza which would
# otherwise fail to resolve.
RUN sed -i '/^\[lints\]$/,/^workspace = true$/d' /usr/src/reactivator/Cargo.toml

WORKDIR /usr/src/reactivator

# Generate Cargo.lock and pin dependencies if needed for Rust 1.86 compatibility
RUN cargo generate-lockfile
# Only update home if it exists as a dependency
RUN cargo update home --precise 0.5.9 || true
RUN cargo install --locked --path .

FROM mcr.microsoft.com/azurelinux/distroless/debug:3.0
COPY --from=builder /usr/lib64/libstdc++.so.6 /usr/lib64/
ENV RUST_BACKTRACE=1
COPY --from=builder /usr/local/cargo/bin/reactivator /usr/local/bin/reactivator
USER root
CMD ["reactivator"]